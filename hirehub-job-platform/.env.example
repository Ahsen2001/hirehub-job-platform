# -----------------------------------------------------------------------------
# HireHub environment template
# Copy this file to .env.local for local development.
# Never commit .env, .env.local, or any file containing real secrets.
# -----------------------------------------------------------------------------

# Supabase PostgreSQL pooled connection.
# Use this for Prisma Client queries in the app.
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase PostgreSQL direct connection.
# Use this for Prisma migrations. If your Supabase project requires IPv4,
# use the direct/session pooler connection string from Supabase.
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Supabase project URL.
# Found in Supabase Dashboard > Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"

# Public anonymous key for browser-safe Supabase access.
# Found in Supabase Dashboard > Project Settings > API.
NEXT_PUBLIC_SUPABASE_ANON_KEY="[SUPABASE_ANON_KEY]"

# Private service role key for trusted server-only operations.
# Never expose this in client components or NEXT_PUBLIC variables.
SUPABASE_SERVICE_ROLE_KEY="[SUPABASE_SERVICE_ROLE_KEY]"

# Supabase Storage bucket used for CV/resume uploads.
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET="resumes"

# Auth secret for NextAuth/Auth.js session encryption.
# Generate with: openssl rand -base64 32
AUTH_SECRET="[AUTH_SECRET]"

# App URL used by auth callbacks and absolute links.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
